<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EmiReminder" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Dark purple window background prevents white flash during cold start -->
        <item name="android:windowBackground">@color/splash_background</item>
        <!-- Android 12+ system splash screen: dark purple bg + ₹ launcher icon -->
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
    </style>
</resources>
